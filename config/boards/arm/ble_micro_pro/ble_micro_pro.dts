/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>

/ {
	model = "BLE Micro Pro";
	compatible = "sekigon,ble-micro-pro";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &code_partition;
	};
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/*
		 * MBR only (0x0..0x1000). This board previously ran QMK BLE, so a
		 * Nordic S140 SoftDevice used to occupy 0x1000..0x26000 and the
		 * bootloader placed the app right after it, at 0x26000. We erased
		 * that stale SoftDevice (erase_softdevice.c); with no SoftDevice
		 * present the bootloader now expects the app immediately after the
		 * MBR, at 0x1000 — so the app must live there.
		 */
		sd_partition: partition@0 {
			label = "mbr";
			reg = <0x00000000 0x00001000>;
		};

		/*
		 * App at 0x1000 (right after the MBR), clean no-SoftDevice layout.
		 * The Adafruit/BMP bootloader lives at the END of flash (~0xf4000
		 * up), and its settings/params pages are the very top pages, so
		 * code_partition and storage must both stay below ~0xf4000.
		 */
		code_partition: partition@1000 {
			label = "code_partition";
			reg = <0x00001000 0x000e3000>;
		};

		storage_partition: partition@e4000 {
			label = "storage";
			reg = <0x000e4000 0x00010000>;
		};
	};
};

/*
 * DIAG: nice!nano's board.dts (the most-used ZMK+nRF52840+BLE board)
 * just does `&gpiote { status = "okay"; }; &gpio0 { status = "okay"; };
 * &gpio1 { status = "okay"; };` with NO explicit gpiote-instance
 * property at all. We had forced BOTH gpio0 and gpio1 onto the same
 * &gpiote0 instance (added earlier for an unrelated build error) —
 * testing whether that static dual-assignment is what's starving BLE
 * of a GPIOTE channel it needs at radio init.
 */
&gpiote0 {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";

	cdc_acm_uart: cdc_acm_uart {
		compatible = "zephyr,cdc-acm-uart";
	};
};

/ {
	chosen {
		zephyr,console = &cdc_acm_uart;
	};
};
